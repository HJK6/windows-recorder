{
  "name": "hf-recorder",
  "version": "0.1.0",
  "private": true,
  "description": "HF Recorder — screen + microphone desktop recorder (Calabrio replacement POC)",
  "main": "src/main/main.js",
  "author": "Vamshi Gujju",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/*.test.js",
    "test:control": "node --test test/control/*.test.js",
    "test:control:electron": "bash test/control/run-electron-control-harness.sh",
    "mock:backend": "node mocks/backend/server.js",
    "mock:flex": "node mocks/flex-console/serve.js",
    "smoke": "bash test/smoke/run-smoke.sh",
    "smoke:save": "bash test/save-harness/run-save-harness.sh",
    "pack": "electron-builder --win --dir",
    "dist": "npm run pack && makensis -DSRC=\"$(pwd)/dist/win-unpacked\" -DOUTFILE=\"$(pwd)/dist/HFRecorder-Setup-$npm_package_version.exe\" -DVERSION=\"$npm_package_version\" build/installer-standalone.nsi"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.healthfirst.hfrecorder",
    "productName": "HFRecorder",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "dir"
      ],
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "ws": "^8.21.0"
  }
}
